# ─────────────────────────────────────────────────────────────────────────────
# Bilingual Review Studio — environment configuration
# Copy to `.env.local` for local dev. The app RUNS WITH NONE OF THESE SET:
# absent provider keys fall back to deterministic fixtures (see config/models.yml).
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM providers (optional) ────────────────────────────────────────────────
# Translator (Anthropic, per spec §6). Without it, the translator uses fixtures.
ANTHROPIC_API_KEY=

# Critic (OpenAI — a DIFFERENT model family from the translator, per spec §6).
# Without it, the critic falls back to the deterministic validator-derived critic.
OPENAI_API_KEY=

# ── Storage backend ──────────────────────────────────────────────────────────
# "file" (default — local JSON store, zero setup) | "supabase"
STORAGE=file

# ── Supabase (only when STORAGE=supabase) ────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Access gate (shared-deployment front-door lock) ──────────────────────────
# When set, every page + API route requires this code (entered once at /gate).
# Stops random visitors from reaching the app or burning LLM credits. Leave
# unset to disable the gate (local dev). Not a replacement for SSO/RBAC.
ACCESS_CODE=

# ── App ───────────────────────────────────────────────────────────────────────
# Comma-separated list of demo seat identities for the mock auth switcher.
# Real deployments replace this with OIDC/SAML + RBAC (spec §11).
NEXT_PUBLIC_AUTH_MODE=mock
